rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated users to read/write their own user document
    // Allow authenticated users to read public profiles for discovery
    match /users/{userId} {
      // Allow users to READ their own document
      allow read: if request.auth != null &&
                  request.auth.uid == userId;

      // Allow authenticated users to READ public user profiles
      allow read: if request.auth != null &&
                  resource.data.userIsPublic == true;

      // Allow users to WRITE/UPDATE their own document
      allow write: if request.auth != null &&
                   request.auth.uid == userId;
    }

    // Plans collection
    match /plans/{planId} {
      function isOwner() {
        return request.auth != null && resource.data.planOwnerId == request.auth.uid;
      }

      function isSharedWithUser() {
        return request.auth != null &&
          (resource.data.planIsShared == true && request.auth.uid in resource.data.get('sharedWithUserIds', []));
      }

      allow read: if request.auth != null &&
        (isOwner() || isSharedWithUser()) &&
        resource.data.planIsDeleted == false;

      allow create: if request.auth != null &&
        request.resource.data.planOwnerId == request.auth.uid;

      allow update, delete: if isOwner();
    }

    // Mind:Set sessions collection
    match /mindset_sessions/{sessionId} {
      function isSessionOwner() {
        return request.auth != null &&
          resource.data.sessionUserId == request.auth.uid;
      }

      allow read: if request.auth != null &&
        resource.data.sessionUserId == request.auth.uid;

      allow create: if request.auth != null &&
        request.resource.data.sessionUserId == request.auth.uid;

      allow update, delete: if isSessionOwner();
    }

    // Allow authenticated users to create activity events for themselves or for others (notifications)
    match /activity_events/{eventId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Allow authenticated users to read/write their own stats
    match /user_stats/{userId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Canonical user stats collection (current app version)
    match /userStats/{userId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read/write their own daily activity
    match /user_daily_activity/{userId}/days/{dateId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // In-app notifications
    match /in_app_notifications/{notificationId} {
      function isSelfNotificationCreate() {
        return request.resource.data.userId == request.auth.uid;
      }

      function isInviteNotificationCreate() {
        return request.resource.data.category == 'invitation' &&
          request.resource.data.relatedId is string &&
          exists(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)) &&
          get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)).data.userId == request.resource.data.userId &&
          (
            request.auth.uid == get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)).data.boardManagerId ||
            request.auth.uid == get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)).data.userId
          );
      }

      function isApprovalNotificationCreate() {
        return request.resource.data.category == 'approval' &&
          request.resource.data.relatedId is string &&
          exists(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)) &&
          exists(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)) &&
          (
            // Reviewer -> submitter (review result)
            (
              request.resource.data.userId ==
                get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.submittedBy &&
              (
                request.auth.uid ==
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskOwnerId ||
                (
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != null &&
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != '' &&
                  (
                    request.auth.uid ==
                      get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.boardManagerId ||
                    get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.memberRoles[request.auth.uid] == 'supervisor'
                  )
                )
              )
            ) ||
            // Assignee -> reviewers (new submission alert)
            (
              request.auth.uid ==
                get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskAssignedTo &&
              (
                request.resource.data.userId ==
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskOwnerId ||
                (
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != null &&
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != '' &&
                  (
                    request.resource.data.userId ==
                      get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.boardManagerId ||
                    get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.memberRoles[request.resource.data.userId] == 'supervisor'
                  )
                )
              )
            )
          );
      }

      function isSuggestionNotificationCreate() {
        return request.resource.data.category == 'reminder' &&
          request.resource.data.relatedId is string &&
          exists(/databases/$(database)/documents/suggestions/$(request.resource.data.relatedId)) &&
          exists(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/suggestions/$(request.resource.data.relatedId)).data.suggestionBoardId)) &&
          request.auth.uid ==
            get(/databases/$(database)/documents/suggestions/$(request.resource.data.relatedId)).data.suggestionAuthorId &&
          request.resource.data.userId ==
            get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/suggestions/$(request.resource.data.relatedId)).data.suggestionBoardId)).data.boardManagerId &&
          request.resource.data.userId != request.auth.uid;
      }

      function hasValidNotificationPayload() {
        return request.resource.data.userId is string &&
          request.resource.data.userId != '' &&
          request.resource.data.title is string &&
          request.resource.data.title != '' &&
          request.resource.data.message is string &&
          request.resource.data.message != '' &&
          request.resource.data.isRead == false &&
          request.resource.data.createdAt is timestamp;
      }

      // Allow any authenticated user to CREATE notifications for any user
      // (for task assignments, board invites, etc)
      allow create: if request.auth != null &&
        hasValidNotificationPayload() &&
        (isSelfNotificationCreate() ||
         isInviteNotificationCreate() ||
         isApprovalNotificationCreate() ||
         isSuggestionNotificationCreate());

      // Allow users to READ their own notifications
      allow read: if request.auth != null &&
                  resource.data.userId == request.auth.uid;

      // Allow users to UPDATE their own notifications (mark as read, etc)
      allow update: if request.auth != null &&
                    resource.data.userId == request.auth.uid;

      // Allow users to DELETE their own notifications
      allow delete: if request.auth != null &&
                    resource.data.userId == request.auth.uid;
    }

    // Push notifications (legacy). Canonical notifications are in_app_notifications.
    match /push_notifications/{notificationId} {
      function isSelfNotificationCreate() {
        return request.resource.data.userId == request.auth.uid;
      }

      function isInviteNotificationCreate() {
        return request.resource.data.category == 'invitation' &&
          request.resource.data.relatedId is string &&
          exists(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)) &&
          get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)).data.userId == request.resource.data.userId &&
          (
            request.auth.uid == get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)).data.boardManagerId ||
            request.auth.uid == get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.relatedId)).data.userId
          );
      }

      function isApprovalNotificationCreate() {
        return request.resource.data.category == 'approval' &&
          request.resource.data.relatedId is string &&
          exists(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)) &&
          exists(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)) &&
          (
            (
              request.resource.data.userId ==
                get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.submittedBy &&
              (
                request.auth.uid ==
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskOwnerId ||
                (
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != null &&
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != '' &&
                  (
                    request.auth.uid ==
                      get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.boardManagerId ||
                    get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.memberRoles[request.auth.uid] == 'supervisor'
                  )
                )
              )
            ) ||
            (
              request.auth.uid ==
                get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskAssignedTo &&
              (
                request.resource.data.userId ==
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskOwnerId ||
                (
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != null &&
                  get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId != '' &&
                  (
                    request.resource.data.userId ==
                      get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.boardManagerId ||
                    get(/databases/$(database)/documents/boards/$(get(/databases/$(database)/documents/tasks/$(get(/databases/$(database)/documents/task_submissions/$(request.resource.data.relatedId)).data.taskId)).data.taskBoardId)).data.memberRoles[request.resource.data.userId] == 'supervisor'
                  )
                )
              )
            )
          );
      }

      function hasValidPushPayload() {
        return request.resource.data.userId is string &&
          request.resource.data.userId != '' &&
          request.resource.data.title is string &&
          request.resource.data.title != '' &&
          request.resource.data.body is string &&
          request.resource.data.body != '' &&
          request.resource.data.isSent == false &&
          request.resource.data.createdAt is timestamp;
      }

      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      // Deprecated client writes: push is now derived from in-app notifications.
      allow create: if false;

      allow update, delete: if false;
    }

    // Email notifications (client writes, sender service consumes)
    match /email_notifications/{notificationId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         resource.data.userEmail == request.auth.token.email);

      allow create: if request.auth != null &&
        request.resource.data.userId is string;

      allow update, delete: if false;
    }

    // Boards collection
    match /boards/{boardId} {
      function isBoardManager() {
        return request.auth != null &&
          request.auth.uid == resource.data.boardManagerId;
      }

      function isBoardMember() {
        return request.auth != null &&
          (
            request.auth.uid in resource.data.memberIds ||
            resource.data.memberRoles[request.auth.uid] in ['member', 'supervisor', 'manager']
          );
      }

      function isRecruitmentType(data) {
        return (
          (data.boardReqType != null && data.boardReqType == 'recruitment') ||
          (!(data.boardReqType != null) &&
            data.requestType != null &&
            data.requestType == 'invitation')
        );
      }

      function isInviteeSelfJoinUpdate() {
        return request.auth != null &&
          request.resource.data.boardLastJoinRequestId is string &&
          request.resource.data.boardLastJoinRequestId != '' &&
          exists(/databases/$(database)/documents/board_join_requests/$(request.resource.data.boardLastJoinRequestId)) &&
          get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.boardLastJoinRequestId)).data.userId == request.auth.uid &&
          get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.boardLastJoinRequestId)).data.boardId == boardId &&
          get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.boardLastJoinRequestId)).data.boardReqStatus == 'approved' &&
          isRecruitmentType(get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.boardLastJoinRequestId)).data) &&
          !(request.auth.uid in resource.data.memberIds) &&
          request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.auth.uid in request.resource.data.memberIds &&
          request.resource.data.memberRoles[request.auth.uid] ==
            get(/databases/$(database)/documents/board_join_requests/$(request.resource.data.boardLastJoinRequestId)).data.boardReqRequestedRole &&
          request.resource.data.memberRoles.diff(resource.data.memberRoles).affectedKeys().hasOnly([request.auth.uid]) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'memberIds',
            'memberRoles',
            'boardLastModifiedAt',
            'boardLastModifiedBy',
            'boardLastJoinRequestId'
          ]);
      }

      // Only boards user manages or belongs to are readable.
      // Members cannot read soft-deleted boards.
      allow read: if isBoardManager() ||
        (isBoardMember() && resource.data.boardIsDeleted == false);

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberIds;

      allow update: if request.auth != null &&
        (isBoardManager() || isInviteeSelfJoinUpdate());

      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.boardManagerId;

      // Board activities subcollection
      match /activities/{activityId} {
        function isBoardMember() {
          return request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId ||
                 request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds;
        }

        // Board members can read activities
        allow read: if request.auth != null && isBoardMember();

        // Board members can create activities
        allow create: if request.auth != null &&
          isBoardMember() &&
          request.resource.data.userId == request.auth.uid;

        // No updates or deletes for activities (immutable log)
        allow update, delete: if false;
      }
    }

    // Board stats collection
    match /boardStats/{statsId} {
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.boardManagerId;

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.boardManagerId;

      allow update: if request.auth != null &&
        request.auth.uid == resource.data.boardManagerId;
    }

    // Board join requests collection
    match /board_join_requests/{requestId} {
      function isRequestTargetUser() {
        return request.auth != null &&
          request.auth.uid == resource.data.userId;
      }

      function isRequestBoardManager() {
        return request.auth != null &&
          get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data.boardManagerId == request.auth.uid;
      }

      function isRequestBoardManagerByField() {
        return request.auth != null &&
          resource.data.boardManagerId == request.auth.uid;
      }

      function isCreateByTargetUser() {
        return request.auth != null &&
          request.auth.uid == request.resource.data.userId;
      }

      function isCreateByBoardManager() {
        return request.auth != null &&
          get(/databases/$(database)/documents/boards/$(request.resource.data.boardId)).data.boardManagerId == request.auth.uid;
      }

      function isResponseOnlyUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'boardReqStatus',
          'boardReqRespondedAt',
          'boardReqRespondedBy',
          'boardReqResponseMessage'
        ]);
      }

      function isValidStatusTransition() {
        return resource.data.boardReqStatus == 'pending' &&
          request.resource.data.boardReqStatus in ['approved', 'rejected'];
      }

      function hasValidResponderMetadata() {
        return request.resource.data.boardReqRespondedBy == request.auth.uid &&
          request.resource.data.boardReqRespondedAt is timestamp;
      }

      function isManagerResponseUpdate() {
        return !boardReqTypeIsRecruitment(resource.data) &&
          (isRequestBoardManager() || isRequestBoardManagerByField()) &&
          isResponseOnlyUpdate() &&
          isValidStatusTransition() &&
          hasValidResponderMetadata();
      }

      function isTargetUserRecruitmentResponseUpdate() {
        return request.auth.uid == resource.data.userId &&
          boardReqTypeIsRecruitment(resource.data) &&
          isResponseOnlyUpdate() &&
          isValidStatusTransition() &&
          hasValidResponderMetadata();
      }

      function boardReqTypeIsRecruitment(data) {
        return (
          (data.boardReqType != null && data.boardReqType == 'recruitment') ||
          (!(data.boardReqType != null) &&
            data.requestType != null &&
            data.requestType == 'invitation')
        );
      }

      // Users can read their own requests; managers can read requests for their board.
      allow read: if isRequestTargetUser() || isRequestBoardManager() || isRequestBoardManagerByField();

      // Managers can create requests (invitations)
      // Users can create requests for themselves (applications)
      allow create: if isCreateByTargetUser() || isCreateByBoardManager();

      // Managers can approve/reject any pending request.
      // Target users can only accept/decline pending recruitment requests.
      allow update: if request.auth != null &&
        (isManagerResponseUpdate() ||
         isTargetUserRecruitmentResponseUpdate());

      // Users can delete their own requests
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Poke collection
    match /pokes/{pokeId} {
      function isCreator() {
        return request.auth != null &&
          request.auth.uid == resource.data.createdByUserId;
      }

      function isRecipient() {
        return request.auth != null &&
          resource.data.recipientUserId != null &&
          request.auth.uid == resource.data.recipientUserId;
      }

      function isBoardTargetMember() {
        return request.auth != null &&
          resource.data.targetType == 'board' &&
          (
            request.auth.uid == get(/databases/$(database)/documents/boards/$(resource.data.targetId)).data.boardManagerId ||
            request.auth.uid in get(/databases/$(database)/documents/boards/$(resource.data.targetId)).data.memberIds
          );
      }

      function isTaskTargetParticipant() {
        let task = get(/databases/$(database)/documents/tasks/$(resource.data.targetId)).data;
        return request.auth != null &&
          resource.data.targetType == 'task' &&
          (
            request.auth.uid == task.taskOwnerId ||
            request.auth.uid == task.taskAssignedTo ||
            (task.taskBoardId != null &&
             task.taskBoardId != '' &&
             (
               request.auth.uid == get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId ||
               request.auth.uid in get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberIds
             ))
          );
      }

      allow read: if isCreator() || isRecipient() || isBoardTargetMember() || isTaskTargetParticipant();

      allow create: if request.auth != null &&
        request.resource.data.createdByUserId == request.auth.uid;

      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.createdByUserId;
    }

    // Suggestions collection
    match /suggestions/{suggestionId} {
      function isBoardMember(boardId) {
        return request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId ||
               request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds;
      }

      function isBoardManager(boardId) {
        return request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId;
      }

      function isBoardSupervisor(boardId) {
        return get(/databases/$(database)/documents/boards/$(boardId)).data.memberRoles[request.auth.uid] == 'supervisor';
      }

      allow read: if request.auth != null &&
        resource.data.suggestionIsDeleted == false &&
        isBoardMember(resource.data.suggestionBoardId);

      allow create: if request.auth != null &&
        request.resource.data.suggestionAuthorId == request.auth.uid &&
        (isBoardManager(request.resource.data.suggestionBoardId) ||
         isBoardSupervisor(request.resource.data.suggestionBoardId));

      allow update: if request.auth != null &&
        (resource.data.suggestionAuthorId == request.auth.uid ||
         isBoardManager(resource.data.suggestionBoardId));

      allow delete: if request.auth != null &&
        isBoardManager(resource.data.suggestionBoardId);
    }

    // Tasks collection
    match /tasks/{taskId} {
      function isBoardMember(boardId) {
        let board = get(/databases/$(database)/documents/boards/$(boardId)).data;
        return request.auth != null &&
          (request.auth.uid == board.boardManagerId ||
           request.auth.uid in board.memberIds ||
           board.memberRoles[request.auth.uid] in ['member', 'supervisor', 'manager']);
      }

      function isBoardManager(boardId) {
        return request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId;
      }

      function isBoardSupervisor(boardId) {
        return request.auth != null &&
          get(/databases/$(database)/documents/boards/$(boardId)).data.memberRoles[request.auth.uid] == 'supervisor';
      }

      allow read: if request.auth != null &&
        (
          resource.data.taskOwnerId == request.auth.uid ||
          resource.data.taskAssignedTo == request.auth.uid ||
          (
            resource.data.taskBoardId != null &&
            resource.data.taskBoardId != '' &&
            isBoardMember(resource.data.taskBoardId)
          )
        ) &&
        resource.data.taskIsDeleted == false;

      allow create: if request.auth != null &&
        (request.resource.data.taskOwnerId == request.auth.uid ||
         (request.resource.data.taskBoardId != null &&
          request.resource.data.taskBoardId != '' &&
          (isBoardManager(request.resource.data.taskBoardId) ||
           (isBoardSupervisor(request.resource.data.taskBoardId) &&
            request.resource.data.taskBoardLane == 'drafts'))));

      allow update: if request.auth != null &&
        resource.data.taskIsDone != true &&
        (
          (
            resource.data.taskBoardId != null &&
            resource.data.taskBoardId != '' &&
            (isBoardManager(resource.data.taskBoardId) ||
             isBoardSupervisor(resource.data.taskBoardId))
          ) ||
          (
            (resource.data.taskBoardId == null ||
             resource.data.taskBoardId == '') &&
            resource.data.taskOwnerId == request.auth.uid
          )
        ) &&
        !(
          resource.data.taskBoardId != null &&
          resource.data.taskBoardId != '' &&
          resource.data.taskBoardLane == 'drafts' &&
          request.resource.data.taskBoardLane == 'published' &&
          !isBoardManager(resource.data.taskBoardId)
        );

      allow delete: if request.auth != null &&
        resource.data.taskIsDone != true &&
        (resource.data.taskOwnerId == request.auth.uid ||
         (resource.data.taskBoardId != null &&
          resource.data.taskBoardId != '' &&
          isBoardManager(resource.data.taskBoardId)));

      // Applications subcollection
      match /applications/{applicationId} {
        function isBoardMember() {
          let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
          return request.auth != null &&
            (
              request.auth.uid == task.taskOwnerId ||
              request.auth.uid == task.taskAssignedTo ||
              (task.taskBoardId != null &&
               (
                 request.auth.uid == get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId ||
                 request.auth.uid in get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberIds
               ))
            );
        }

        function isBoardTaskManager() {
          let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
          return request.auth != null &&
            task.taskBoardId != null &&
            task.taskBoardId != '' &&
            get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId == request.auth.uid;
        }

        allow read: if isBoardMember();

        allow create: if request.auth != null &&
          request.resource.data.userId == request.auth.uid &&
          !isBoardTaskManager();

        allow delete: if request.auth != null &&
          request.auth.uid == resource.data.userId;

        allow update: if false;
      }
    }

    // Task stats collection
    match /task_stats/{taskId} {
      function hasTaskAccess() {
        let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
        return request.auth != null &&
          (request.auth.uid == task.taskOwnerId ||
           request.auth.uid == task.taskAssignedTo);
      }

      allow read: if hasTaskAccess();
      allow write: if hasTaskAccess();
      allow create: if hasTaskAccess();
      allow delete: if hasTaskAccess();
    }

    // Subtasks collection
    match /subtasks/{subtaskId} {
      function parentTask(taskId) {
        return get(/databases/$(database)/documents/tasks/$(taskId)).data;
      }

      function isParentTaskAccessible(taskId) {
        let task = parentTask(taskId);
        return request.auth.uid == task.taskOwnerId ||
               request.auth.uid == task.taskAssignedTo ||
               (task.taskBoardId != null &&
                task.taskBoardId != '' &&
                request.auth.uid in get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberIds);
      }

      function isParentTaskAssignee(taskId) {
        let task = parentTask(taskId);
        return request.auth != null && request.auth.uid == task.taskAssignedTo;
      }

      function isParentTaskOpen(taskId) {
        let task = parentTask(taskId);
        return task.taskIsDone != true;
      }

      allow read: if request.auth != null &&
        (resource.data.subtaskOwnerId == request.auth.uid ||
         resource.data.subtaskAssignedTo == request.auth.uid ||
         isParentTaskAccessible(resource.data.parentTaskId)) &&
        resource.data.subtaskIsDeleted == false;

      allow create: if request.auth != null &&
        isParentTaskAssignee(request.resource.data.parentTaskId) &&
        isParentTaskOpen(request.resource.data.parentTaskId);

      allow update: if request.auth != null &&
        isParentTaskAssignee(resource.data.parentTaskId) &&
        isParentTaskOpen(resource.data.parentTaskId);

      allow delete: if request.auth != null &&
        isParentTaskAssignee(resource.data.parentTaskId) &&
        isParentTaskOpen(resource.data.parentTaskId);
    }

    // Task submissions collection
    match /task_submissions/{submissionId} {
      function taskById(taskId) {
        let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
        return task;
      }

      function canAccessTaskSubmissions(taskId) {
        let task = taskById(taskId);
        let isBoardTask = task.taskBoardId != null && task.taskBoardId != '';

        return request.auth.uid == task.taskOwnerId ||
               request.auth.uid == task.taskAssignedTo ||
               (isBoardTask &&
                (request.auth.uid == get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId ||
                 request.auth.uid in get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberIds));
      }

      function isTaskAssignee(taskId) {
        let task = taskById(taskId);
        return request.auth != null && request.auth.uid == task.taskAssignedTo;
      }

      function canReviewTaskSubmissions(taskId) {
        let task = taskById(taskId);
        let isBoardTask = task.taskBoardId != null && task.taskBoardId != '';
        return request.auth != null &&
          (request.auth.uid == task.taskOwnerId ||
           (isBoardTask &&
            (request.auth.uid == get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId ||
             get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberRoles[request.auth.uid] == 'supervisor')));
      }

      function isTaskOpen(taskId) {
        let task = taskById(taskId);
        return task.taskIsDone != true;
      }

      function reviewFieldsOnly() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'feedback',
          'reviewedAt',
          'reviewedBy',
          'revisionTaskId'
        ]);
      }

      function isValidReviewStatus() {
        return request.resource.data.status in [
          'approved',
          'rejected',
          'revision_requested'
        ];
      }

      function hasValidReviewPayload() {
        return request.resource.data.reviewedBy == request.auth.uid &&
          request.resource.data.reviewedAt is timestamp &&
          request.resource.data.taskId == resource.data.taskId &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          request.resource.data.submittedAt == resource.data.submittedAt &&
          (!('feedback' in request.resource.data) ||
           request.resource.data.feedback == null ||
           request.resource.data.feedback is string) &&
          (!('revisionTaskId' in request.resource.data) ||
           request.resource.data.revisionTaskId == null ||
           request.resource.data.revisionTaskId is string);
      }

      // Allow read if user can access the task
      allow read: if request.auth != null &&
        canAccessTaskSubmissions(resource.data.taskId);

      // Only assigned member can create submissions
      allow create: if request.auth != null &&
        request.resource.data.submittedBy == request.auth.uid &&
        isTaskAssignee(request.resource.data.taskId) &&
        isTaskOpen(request.resource.data.taskId);

      // Only the submitter or task owner/manager can update
      allow update: if request.auth != null &&
        isTaskOpen(resource.data.taskId) &&
        canReviewTaskSubmissions(resource.data.taskId) &&
        reviewFieldsOnly() &&
        isValidReviewStatus() &&
        hasValidReviewPayload();

      // Only the submitter or task owner/manager can delete
      allow delete: if request.auth != null &&
        isTaskOpen(resource.data.taskId) &&
        (resource.data.submittedBy == request.auth.uid &&
         isTaskAssignee(resource.data.taskId));
    }

    // Task volunteer requests collection
    match /task_volunteer_requests/{requestId} {
      function isBoardManagerForRequest() {
        let boardId = resource.data.boardId;
        return request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId;
      }

      // Board members can read requests for their boards
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid in get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data.memberIds);

      // Board members can create volunteer requests
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/boards/$(request.resource.data.boardId)).data.memberIds;

      // Only board manager can update (accept/decline)
      allow update: if request.auth != null && isBoardManagerForRequest();

      // User can delete their own pending request
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        resource.data.status == 'pending';
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

