rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated users to read/write their own user document
    // Allow authenticated users to read public profiles for discovery
    match /users/{userId} {
      // Allow users to READ their own document
      allow read: if request.auth != null &&
                  request.auth.uid == userId;

      // Allow authenticated users to READ public user profiles
      allow read: if request.auth != null &&
                  resource.data.userIsPublic == true;

      // Allow users to WRITE/UPDATE their own document
      allow write: if request.auth != null &&
                   request.auth.uid == userId;
    }

    // Plans collection
    match /plans/{planId} {
      function isOwner() {
        return request.auth != null && resource.data.planOwnerId == request.auth.uid;
      }

      function isSharedWithUser() {
        return request.auth != null &&
          (resource.data.planIsShared == true && request.auth.uid in resource.data.get('sharedWithUserIds', []));
      }

      allow read: if request.auth != null &&
        (isOwner() || isSharedWithUser()) &&
        resource.data.planIsDeleted == false;

      allow create: if request.auth != null &&
        request.resource.data.planOwnerId == request.auth.uid;

      allow update, delete: if isOwner();
    }

    // Mind:Set sessions collection
    match /mindset_sessions/{sessionId} {
      function isSessionOwner() {
        return request.auth != null &&
          resource.data.sessionUserId == request.auth.uid;
      }

      allow read: if request.auth != null &&
        resource.data.sessionUserId == request.auth.uid;

      allow create: if request.auth != null &&
        request.resource.data.sessionUserId == request.auth.uid;

      allow update, delete: if isSessionOwner();
    }

    // Allow authenticated users to create activity events for themselves or for others (notifications)
    match /activity_events/{eventId} {
      function canReadBoardActivity() {
        return request.auth != null &&
          resource.data.boardId is string &&
          resource.data.boardId != '' &&
          exists(/databases/$(database)/documents/boards/$(resource.data.boardId)) &&
          (
            request.auth.uid ==
              get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data.boardManagerId ||
            request.auth.uid in
              get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data.memberIds
          );
      }

      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || canReadBoardActivity());
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Allow authenticated users to read/write their own stats
    match /user_stats/{userId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read/write their own daily activity
    match /user_daily_activity/{userId}/days/{dateId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Boards collection
    match /boards/{boardId} {
      function isBoardManager() {
        return request.auth != null &&
          request.auth.uid == resource.data.boardManagerId;
      }

      function isBoardMember() {
        return request.auth != null &&
          (
            request.auth.uid in resource.data.memberIds ||
            resource.data.memberRoles[request.auth.uid] in ['member', 'supervisor', 'manager']
          );
      }

      function hasPendingBoardInvite() {
        return request.auth != null &&
          request.auth.uid in resource.data.get('pendingInviteUserIds', []);
      }

      function canAcceptBoardInvite() {
        return request.auth != null &&
          !(request.auth.uid in resource.data.memberIds) &&
          request.auth.uid in resource.data.get('pendingInviteUserIds', []) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'memberIds',
            'memberRoles',
            'pendingInviteUserIds',
            'boardLastThoughtId',
            'boardLastModifiedAt',
            'boardLastModifiedBy'
          ]) &&
          request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.auth.uid in request.resource.data.memberIds &&
          request.resource.data.memberRoles[request.auth.uid] in ['member', 'supervisor'] &&
          resource.data.get('pendingInviteUserIds', []).size() ==
            request.resource.data.get('pendingInviteUserIds', []).size() + 1 &&
          resource.data.get('pendingInviteUserIds', [])
            .hasAll(request.resource.data.get('pendingInviteUserIds', [])) &&
          !(request.auth.uid in request.resource.data.get('pendingInviteUserIds', [])) &&
          request.resource.data.memberRoles.diff(resource.data.memberRoles)
            .affectedKeys()
            .hasOnly([request.auth.uid]);
      }

      // Only boards user manages or belongs to are readable.
      // Members cannot read soft-deleted boards.
      allow read: if isBoardManager() ||
        (isBoardMember() && resource.data.boardIsDeleted == false) ||
        (hasPendingBoardInvite() && resource.data.boardIsDeleted == false);

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberIds;

      allow update: if request.auth != null &&
        (isBoardManager() || canAcceptBoardInvite());

      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.boardManagerId;

      // Board activities subcollection
      match /activities/{activityId} {
        function isBoardMember() {
          return request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId ||
                 request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds;
        }

        // Board members can read activities
        allow read: if request.auth != null && isBoardMember();

        // Board members can create activities
        allow create: if request.auth != null &&
          isBoardMember() &&
          request.resource.data.userId == request.auth.uid;

        // No updates or deletes for activities (immutable log)
        allow update, delete: if false;
      }
    }
    // Tasks collection
    match /tasks/{taskId} {
      function isBoardMember(boardId) {
        let board = get(/databases/$(database)/documents/boards/$(boardId)).data;
        return request.auth != null &&
          (request.auth.uid == board.boardManagerId ||
           request.auth.uid in board.memberIds ||
           board.memberRoles[request.auth.uid] in ['member', 'supervisor', 'manager']);
      }

      function isBoardManager(boardId) {
        return request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId;
      }

      function isBoardSupervisor(boardId) {
        return request.auth != null &&
          get(/databases/$(database)/documents/boards/$(boardId)).data.memberRoles[request.auth.uid] == 'supervisor';
      }

      function isAssigneeReminderUpdate() {
        return request.auth.uid == resource.data.taskAssignedTo &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'taskReminderSentAt',
            'taskDeadlineMissed'
          ]);
      }

      function isAssigneeWorkflowStatusUpdate() {
        return resource.data.taskIsDone != true &&
          request.auth.uid == resource.data.taskAssignedTo &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'taskStatus'
          ]) &&
          request.resource.data.taskStatus in ['To Do', 'In Progress', 'Paused'];
      }

      function isAssigneeSubmissionUpdate() {
        return resource.data.taskIsDone != true &&
          request.auth.uid == resource.data.taskAssignedTo &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'taskStatus',
            'taskApprovalStatus',
            'taskLatestSubmissionThoughtId'
          ]) &&
          request.resource.data.taskStatus == 'Submitted' &&
          request.resource.data.taskApprovalStatus == 'pending';
      }

      allow read: if request.auth != null &&
        (
          resource.data.taskOwnerId == request.auth.uid ||
          resource.data.taskAssignedTo == request.auth.uid ||
          (
            resource.data.taskBoardId != null &&
            resource.data.taskBoardId != '' &&
            isBoardMember(resource.data.taskBoardId)
          )
        ) &&
        resource.data.taskIsDeleted == false;

      allow create: if request.auth != null &&
        (request.resource.data.taskOwnerId == request.auth.uid ||
         (request.resource.data.taskBoardId != null &&
          request.resource.data.taskBoardId != '' &&
          (isBoardManager(request.resource.data.taskBoardId) ||
           (isBoardSupervisor(request.resource.data.taskBoardId) &&
            request.resource.data.taskBoardLane == 'drafts'))));

      allow update: if request.auth != null &&
        (
          (
            // Assigned members can only update reminder fields and limited workflow fields.
            isAssigneeReminderUpdate() ||
            isAssigneeWorkflowStatusUpdate() ||
            isAssigneeSubmissionUpdate()
          ) ||
          (
            resource.data.taskIsDone != true &&
            (
              (
                resource.data.taskBoardId != null &&
                resource.data.taskBoardId != '' &&
                (isBoardManager(resource.data.taskBoardId) ||
                 isBoardSupervisor(resource.data.taskBoardId))
              ) ||
              (
                (resource.data.taskBoardId == null ||
                 resource.data.taskBoardId == '') &&
                resource.data.taskOwnerId == request.auth.uid
              )
            ) &&
            !(
              resource.data.taskBoardId != null &&
              resource.data.taskBoardId != '' &&
              resource.data.taskBoardLane == 'drafts' &&
              request.resource.data.taskBoardLane == 'published' &&
              !isBoardManager(resource.data.taskBoardId)
            )
          )
        );

      allow delete: if request.auth != null &&
        resource.data.taskIsDone != true &&
        (resource.data.taskOwnerId == request.auth.uid ||
         (resource.data.taskBoardId != null &&
          resource.data.taskBoardId != '' &&
          isBoardManager(resource.data.taskBoardId)));

    }

    // Task stats collection
    match /task_stats/{taskId} {
      function hasTaskAccess() {
        let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
        return request.auth != null &&
          (request.auth.uid == task.taskOwnerId ||
           request.auth.uid == task.taskAssignedTo);
      }

      allow read: if hasTaskAccess();
      allow write: if hasTaskAccess();
      allow create: if hasTaskAccess();
      allow delete: if hasTaskAccess();
    }

    // Task uploads collection
    match /task_uploads/{uploadId} {
      function parentTask(taskId) {
        return get(/databases/$(database)/documents/tasks/$(taskId)).data;
      }

      function taskExists(taskId) {
        return taskId is string &&
          taskId != '' &&
          exists(/databases/$(database)/documents/tasks/$(taskId));
      }

      function hasTaskAccess(taskId) {
        let task = parentTask(taskId);
        return request.auth != null &&
          taskExists(taskId) &&
          (
            request.auth.uid == task.taskOwnerId ||
            request.auth.uid == task.taskAssignedTo ||
            (
              task.taskBoardId is string &&
              task.taskBoardId != '' &&
              request.auth.uid in get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberIds
            ) ||
            (
              task.taskBoardId is string &&
              task.taskBoardId != '' &&
              request.auth.uid ==
                get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId
            )
          );
      }

      function canManageTask(taskId) {
        let task = parentTask(taskId);
        return request.auth != null &&
          taskExists(taskId) &&
          (
            request.auth.uid == task.taskOwnerId ||
            (
              task.taskBoardId is string &&
              task.taskBoardId != '' &&
              (
                request.auth.uid ==
                  get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId ||
                get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberRoles[request.auth.uid]
                  == 'supervisor'
              )
            )
          );
      }

      function preservesImmutableFields() {
        return request.resource.data.taskId == resource.data.taskId &&
          request.resource.data.boardId == resource.data.boardId &&
          request.resource.data.uploadedByUserId == resource.data.uploadedByUserId &&
          request.resource.data.fileName == resource.data.fileName &&
          request.resource.data.fileUrl == resource.data.fileUrl &&
          request.resource.data.filePublicId == resource.data.filePublicId &&
          request.resource.data.uploadedAt == resource.data.uploadedAt;
      }

      allow read: if hasTaskAccess(resource.data.taskId) &&
        resource.data.isDeleted == false;

      allow create: if request.auth != null &&
        request.resource.data.uploadedByUserId == request.auth.uid &&
        hasTaskAccess(request.resource.data.taskId);

      allow update: if request.auth != null &&
        preservesImmutableFields() &&
        (
          request.auth.uid == resource.data.uploadedByUserId ||
          canManageTask(resource.data.taskId)
        );

      allow delete: if request.auth != null &&
        (
          request.auth.uid == resource.data.uploadedByUserId ||
          canManageTask(resource.data.taskId)
        );
    }

    // Steps collection
    match /steps/{stepId} {
      function parentTask(taskId) {
        return get(/databases/$(database)/documents/tasks/$(taskId)).data;
      }

      function isParentTaskAccessible(taskId) {
        let task = parentTask(taskId);
        return request.auth.uid == task.taskOwnerId ||
               request.auth.uid == task.taskAssignedTo ||
               (task.taskBoardId != null &&
                task.taskBoardId != '' &&
                request.auth.uid in get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberIds);
      }

      function canManageParentTask(taskId) {
        let task = parentTask(taskId);
        return request.auth != null &&
          (
            request.auth.uid == task.taskOwnerId ||
            request.auth.uid == task.taskAssignedTo ||
            (
              task.taskBoardId != null &&
              task.taskBoardId != '' &&
              (
                request.auth.uid == get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.boardManagerId ||
                get(/databases/$(database)/documents/boards/$(task.taskBoardId)).data.memberRoles[request.auth.uid] == 'supervisor'
              )
            )
          );
      }

      function isParentTaskOpen(taskId) {
        let task = parentTask(taskId);
        return task.taskIsDone != true;
      }

      allow read: if request.auth != null &&
        (resource.data.stepOwnerId == request.auth.uid ||
         resource.data.stepAssignedTo == request.auth.uid ||
         isParentTaskAccessible(resource.data.parentTaskId)) &&
        resource.data.stepIsDeleted == false;

      allow create: if request.auth != null &&
        canManageParentTask(request.resource.data.parentTaskId) &&
        isParentTaskOpen(request.resource.data.parentTaskId);

      allow update: if request.auth != null &&
        canManageParentTask(resource.data.parentTaskId) &&
        isParentTaskOpen(resource.data.parentTaskId);

      allow delete: if request.auth != null &&
        canManageParentTask(resource.data.parentTaskId) &&
        isParentTaskOpen(resource.data.parentTaskId);
    }

    // Task volunteer requests collection
    match /task_volunteer_requests/{volunteerRequestId} {
      function isBoardManagerForRequest() {
        let boardId = resource.data.boardId;
        return request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId;
      }

      // Board members can read requests for their boards
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid in get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data.memberIds);

      // Board members can create volunteer requests
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/boards/$(request.resource.data.boardId)).data.memberIds;

      // Only board manager can update (accept/decline)
      allow update: if request.auth != null && isBoardManagerForRequest();

      // User can delete their own pending request
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        resource.data.status == 'pending';
    }

    // Notifications collection
    match /notifications/{notificationId} {
      function boardExists(boardId) {
        return boardId is string &&
          boardId != '' &&
          exists(/databases/$(database)/documents/boards/$(boardId));
      }

      function taskExists(taskId) {
        return taskId is string &&
          taskId != '' &&
          exists(/databases/$(database)/documents/tasks/$(taskId));
      }

      function isBoardParticipant(boardId) {
        return request.auth != null &&
          boardExists(boardId) &&
          (
            request.auth.uid ==
              get(/databases/$(database)/documents/boards/$(boardId)).data.boardManagerId ||
            request.auth.uid in
              get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds ||
            get(/databases/$(database)/documents/boards/$(boardId)).data.memberRoles[request.auth.uid]
              in ['member', 'supervisor', 'manager']
          );
      }

      function hasTaskAccess(taskId) {
        let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
        return request.auth != null &&
          taskExists(taskId) &&
          (
            request.auth.uid == task.taskOwnerId ||
            request.auth.uid == task.taskAssignedTo ||
            (
              task.taskBoardId is string &&
              task.taskBoardId != '' &&
              isBoardParticipant(task.taskBoardId)
            )
          );
      }

      function isRecipient() {
        return request.auth != null &&
          request.auth.uid == resource.data.recipientUserId;
      }

      function isValidCreate() {
        let data = request.resource.data;
        let boardId = data.get('boardId', null);
        let taskId = data.get('taskId', null);
        return request.auth != null &&
          data.actorUserId is string &&
          data.actorUserId == request.auth.uid &&
          data.recipientUserId is string &&
          data.recipientUserId != '' &&
          data.title is string &&
          data.message is string &&
          data.type is string &&
          data.isRead == false &&
          data.isDeleted == false &&
          data.createdAt is timestamp &&
          data.updatedAt is timestamp &&
          (
            !(boardId is string) ||
            boardId == '' ||
            boardExists(boardId)
          ) &&
          (
            !(taskId is string) ||
            taskId == '' ||
            taskExists(taskId)
          );
      }

      allow read: if request.auth != null &&
        (
          isRecipient() ||
          (
            resource.data.boardId is string &&
            resource.data.boardId != '' &&
            isBoardParticipant(resource.data.boardId)
          ) ||
          (
            resource.data.taskId is string &&
            resource.data.taskId != '' &&
            hasTaskAccess(resource.data.taskId)
          )
        ) &&
        resource.data.isDeleted == false;

      allow create: if isValidCreate();

      allow update: if request.auth != null && isRecipient();

      allow delete: if request.auth != null && isRecipient();
    }

    // Thoughts collection
    match /thoughts/{thoughtId} {
      function boardExists(boardId) {
        return boardId is string &&
          boardId != '' &&
          exists(/databases/$(database)/documents/boards/$(boardId));
      }

      function boardData(boardId) {
        return get(/databases/$(database)/documents/boards/$(boardId)).data;
      }

      function isBoardMember(boardId) {
        return request.auth != null &&
          boardExists(boardId) &&
          (
            request.auth.uid == boardData(boardId).boardManagerId ||
            request.auth.uid in boardData(boardId).memberIds ||
            boardData(boardId).memberRoles[request.auth.uid] in ['member', 'supervisor', 'manager']
          );
      }

      function isBoardManager(boardId) {
        return request.auth != null &&
          boardExists(boardId) &&
          request.auth.uid == boardData(boardId).boardManagerId;
      }

      function isBoardSupervisor(boardId) {
        return request.auth != null &&
          boardExists(boardId) &&
          boardData(boardId).memberRoles[request.auth.uid] == 'supervisor';
      }

      function taskExists(taskId) {
        return taskId is string &&
          taskId != '' &&
          exists(/databases/$(database)/documents/tasks/$(taskId));
      }

      function taskData(taskId) {
        return get(/databases/$(database)/documents/tasks/$(taskId)).data;
      }

      function hasTaskAccess(taskId) {
        return request.auth != null &&
          taskExists(taskId) &&
          (
            request.auth.uid == taskData(taskId).taskOwnerId ||
            request.auth.uid == taskData(taskId).taskAssignedTo ||
            (
              taskData(taskId).taskBoardId is string &&
              taskData(taskId).taskBoardId != '' &&
              isBoardMember(taskData(taskId).taskBoardId)
            )
          );
      }

      function canManageThought(thoughtData) {
        return request.auth != null &&
          (
            request.auth.uid == thoughtData.authorId ||
            request.auth.uid == thoughtData.targetUserId ||
            (
              thoughtData.boardId is string &&
              thoughtData.boardId != '' &&
              (isBoardManager(thoughtData.boardId) || isBoardSupervisor(thoughtData.boardId))
            ) ||
            (
              thoughtData.taskId is string &&
              thoughtData.taskId != '' &&
              hasTaskAccess(thoughtData.taskId)
            )
          );
      }

      function canReadThought(thoughtData) {
        return request.auth != null &&
          (
            request.auth.uid == thoughtData.authorId ||
            request.auth.uid == thoughtData.targetUserId ||
            (
              thoughtData.boardId is string &&
              thoughtData.boardId != '' &&
              isBoardMember(thoughtData.boardId)
            ) ||
            (
              thoughtData.taskId is string &&
              thoughtData.taskId != '' &&
              hasTaskAccess(thoughtData.taskId)
            )
          ) &&
          thoughtData.isDeleted == false;
      }

      function isValidThoughtCreate() {
        let data = request.resource.data;
        let boardId = data.boardId;
        let taskId = data.taskId;
        let metadata = data.get('metadata', {});
        let isBoardRequestAccess =
          data.type == 'board_request' &&
          metadata.requestDirection == 'request_board_access';

        return request.auth != null &&
          data.authorId == request.auth.uid &&
          data.isDeleted == false &&
          (
            !(boardId is string) ||
            boardId == '' ||
            isBoardMember(boardId) ||
            (
              isBoardRequestAccess &&
              boardExists(boardId) &&
              data.targetUserId == boardData(boardId).boardManagerId
            )
          ) &&
          (
            !(taskId is string) ||
            taskId == '' ||
            hasTaskAccess(taskId)
          );
      }

      function keepsImmutableCoreFields() {
        return request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.type == resource.data.type &&
          request.resource.data.scopeType == resource.data.scopeType &&
          request.resource.data.boardId == resource.data.boardId &&
          request.resource.data.taskId == resource.data.taskId;
      }

      allow read: if canReadThought(resource.data);
      allow create: if isValidThoughtCreate();
      allow update: if canManageThought(resource.data) && keepsImmutableCoreFields();
      allow delete: if request.auth != null &&
        (
          request.auth.uid == resource.data.authorId ||
          (
            resource.data.boardId is string &&
            resource.data.boardId != '' &&
            isBoardManager(resource.data.boardId)
          )
        );
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
